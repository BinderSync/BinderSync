// Prisma schema for BinderSync
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  free
  pro
  master
}

enum Look {
  Gallery
  Linen
  Night
}

enum Currency {
  USD
  EUR
}

// --- Auth.js tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App tables ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  plan             Plan     @default(free)
  currency         Currency @default(USD)
  binderColor      String?
  look             Look     @default(Gallery)
  stripeCustomerId String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  ownedCards   OwnedCard[]
  sellBinders  SellBinder[]
}

model OwnedCard {
  id      String  @id @default(cuid())
  userId  String
  cardId  String
  variant String  @default("base")
  owned   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId, variant])
}

model SellBinder {
  id          String   @id @default(cuid())
  userId      String
  title       String
  note        String?
  shareId     String   @unique @default(cuid())
  isPublished Boolean  @default(false)
  color       String?
  showPrices  Boolean  @default(true)
  size        Int      @default(9)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards SellBinderCard[]
}

model SellBinderCard {
  id           String  @id @default(cuid())
  sellBinderId String
  cardId       String
  variant      String  @default("base")
  slotPosition Int
  price        Decimal @db.Decimal(10, 2)
  condition    String  @default("NM")

  sellBinder SellBinder @relation(fields: [sellBinderId], references: [id], onDelete: Cascade)
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([sellBinderId, cardId, variant])
}

model Series {
  id    String @id
  name  String
  order Int    @default(0)

  sets Set[]
}

model Set {
  id           String    @id
  seriesId     String
  name         String
  logoUrl      String?
  symbolUrl    String?
  cardCount    Int       @default(0)
  releaseDate  DateTime?
  position     Int       @default(0)

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cards  Card[]
}

model Card {
  id          String  @id
  setId       String
  name        String
  number      String
  imageUrl    String?
  rarity      String?
  hasReverse  Boolean @default(false)

  set             Set              @relation(fields: [setId], references: [id], onDelete: Cascade)
  ownedBy         OwnedCard[]
  sellBinderCards SellBinderCard[]
  priceSnapshots  PriceSnapshot[]

  @@index([setId])
  @@index([name])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  cardId    String
  variant   String   @default("base")
  source    String
  price     Decimal  @db.Decimal(10, 2)
  currency  Currency @default(USD)
  fetchedAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, variant, fetchedAt])
}
